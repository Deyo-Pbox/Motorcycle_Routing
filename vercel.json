{
  "buildCommand": "pip install -r requirements.txt",
  "devCommand": "python -m flask --app web.app run",
  "env": {
    "FLASK_ENV": "production"
  },
  "functions": {
    "web/app.py": {
      "runtime": "python3.11",
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/web/app.py"
    }
  ]
}
